<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head.ejs') %>
</head>
<body class="bg">
        <%- include('../partials/headerAdmin.ejs', {username}) %>
        <br><br><br><br>
        <div class="container">
            <div class="row">
                <div class="col-sm"></div>
                <div class="col-sm">
                    <div class="card card-signup z-depth-0 bg-light text-center">
                        <div class="card-body">
                                <h2>Add Train</h2>
                                <form action="/admin/addTrain" method="post">
                                    <label>Name : </label><br>
                                    <input type="text" name="name"><br>
                                    <label>Destination</label><br>
                                    <select name="DestinationId">
                                        <% result.map(data => { %> 
                                            <option value="<%= data.id %>"><%= data.name %></option>
                                        <%})%>
                                    </select><br>
                                    <label>Departure</label><br>
                                    <select name="departure">
                                        <option value="Pagi">Pagi</option>
                                        <option value="Malam">Malam</option>
                                    </select><br>
                                    <label>Price</label><br>
                                    <input type="number" name="price"><br>
                                    <label>Number of Seat</label><br>
                                    <input type="number" name="seats"><br>
                                    <input type="submit" value="Add New">
                                </form>
                        </div>
                    </div>
                </div>
                <div class="col-sm"></div>
            </div>
        </div>
        <%- include('../partials/jquery.ejs') %>
    
</body>
</html>